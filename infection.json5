{
  "$schema": "https://raw.githubusercontent.com/infection/infection/master/resources/schema.json",
  "source": {
    "directories": ["src"]
  },
  "logs": {
    "summary": "build/infection-summary.log"
  },
  "mutators": {
    "@default": true
  },
  "phpUnit": {
    "customPath": "vendor-bin/phpunit/vendor/bin/phpunit"
  },
  "minMsi": 75,
  "minCoveredMsi": 82,
  "testFramework": "phpunit",
  "timeout": 120
}
